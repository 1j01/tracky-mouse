{
	"configurations": [
		{
			"name": "Win32",
			"includePath": [
				"${workspaceFolder}",
				// Path to Node.js headers so IntelliSense can find node_api.h
				"${env:USERPROFILE}/.electron-gyp/20.0.1/include/node"
			],
			"defines": [
				"_DEBUG",
				"UNICODE",
				"_UNICODE"
			],
			"cStandard": "c17",
			"cppStandard": "c++17",
			"intelliSenseMode": "windows-msvc-x64"
		}
	],
	"version": 4
}