{
  "private": true,
  "name": "tracky-mouse-website",
  "version": "2.6.0",
  "description": "Website for Tracky Mouse",
  "devDependencies": {
    "gh-pages": "^6.1.1",
    "live-server": "^1.2.1"
  },
  "scripts": {
    "start": "live-server --port=64206 --no-browser",
    "test": "node ../scripts/copy-with-review.js . ../dist globs-for-deploy.js --dry-run",
    "deploy": "rm -rf ../dist && node ../scripts/copy-with-review.js . ../dist globs-for-deploy.js && gh-pages -d ../dist",
    "deploy:rollback": "git fetch origin gh-pages && git push --force-with-lease origin origin/gh-pages~1:gh-pages"
  },
  "license": "MIT"
}
